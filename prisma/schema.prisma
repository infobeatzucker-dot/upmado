generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  image                String?   // Google profile picture
  emailVerified        DateTime? // Required by NextAuth
  password             String?   // bcrypt hash (null for Google-only accounts)
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  orders        Order[]
  masters       Master[]
}

// NextAuth OAuth account linking (Google etc.)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth email verification tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  // Plan types: free | ppu | creator_monthly | creator_annual |
  //             pro_monthly | pro_annual | proplus_monthly | proplus_annual |
  //             studio_monthly | studio_annual
  planType             String
  paypalSubscriptionId String    @unique
  status               String    // "active" | "cancelled" | "suspended"
  validUntil           DateTime
  mastersUsed          Int       @default(0)
  mastersLimit         Int       @default(25)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id              String    @id @default(cuid())
  userId          String?
  paypalOrderId   String    @unique
  amount          Float
  currency        String    @default("EUR")
  status          String    // "pending" | "completed" | "refunded"
  masterId        String?
  downloadExpires DateTime?
  createdAt       DateTime  @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  master Master? @relation(fields: [masterId], references: [id])
}

model Master {
  id           String   @id @default(cuid())
  userId       String?
  fileId       String
  originalName String
  platform     String
  preset       String
  status       String   @default("pending") // "pending" | "processing" | "done" | "error"

  // Analysis results (JSON strings)
  preAnalysis  String?
  postAnalysis String?
  aiParams     String?

  // Output file paths (valid for 2h after processing)
  pathWav32    String?
  pathWav24    String?
  pathWav16    String?
  pathFlac     String?
  pathMp3320   String?
  pathMp3128   String?
  pathAac256   String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  orders Order[]
}
